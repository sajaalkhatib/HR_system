@model IEnumerable<DepartmentDto>

@{
    ViewData["Title"] = "Departments";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-success text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-building-fill"></i> Departments</h5>
        <a asp-action="Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> Add Department
        </a>
    </div>
    <div class="card-body">
        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-building text-muted" style="font-size: 3rem;"></i>
                <h5 class="text-muted mt-3">No departments found</h5>
                <p class="text-muted">Click "Add Department" to create the first department.</p>
            </div>
        }
        else
        {
            <div class="row g-3">
                @foreach (var department in Model)
                {
                    <div class="col-md-4">
                        <div class="card border-success shadow-sm h-100">
                            <div class="card-body text-center">
                                <i class="bi bi-building-fill text-success" style="font-size: 2.5rem;"></i>
                                <h5 class="card-title mt-2">@department.DepartmentName</h5>
                                <p class="card-text">
                                    <span class="badge bg-info text-white">@department.EmployeeCount Employee(s)</span>
                                </p>
                                <form asp-action="Delete" asp-route-id="@department.DepartmentId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this department?');">
                                    @Html.AntiForgeryToken()
                                    <button type="submit" class="btn btn-outline-danger btn-sm">
                                        <i class="bi bi-trash"></i> Delete
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>