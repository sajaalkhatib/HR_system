@model IEnumerable<EmployeeDto>

@{
    ViewData["Title"] = "Employees";
}

<div class="card shadow-sm border-0">
    <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-person-badge-fill"></i> Employees</h5>
        <a asp-action="Create" class="btn btn-light btn-sm">
            <i class="bi bi-plus-circle"></i> Add Employee
        </a>
    </div>
    <div class="card-body">
        <!-- Search Section -->
        <div class="row mb-4">
            <div class="col-md-6">
                <form asp-action="Search" method="get" class="d-flex">
                    <input type="text" name="searchTerm" class="form-control me-2" placeholder="Search by name, email, or job title..." value="@ViewBag.SearchTerm" />
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-search"></i> Search
                    </button>
                </form>
            </div>
            <div class="col-md-6">
                <form asp-action="SearchByDepartment" method="get" class="d-flex">
                    <input type="text" name="departmentName" class="form-control me-2" placeholder="Search by department name..." value="@ViewBag.SearchDepartment" />
                    <button type="submit" class="btn btn-info text-white">
                        <i class="bi bi-search"></i> Search by Dept
                    </button>
                </form>
            </div>
        </div>

        @if (!Model.Any())
        {
            <div class="text-center py-5">
                <i class="bi bi-people text-muted" style="font-size: 3rem;"></i>
                <h5 class="text-muted mt-3">No employees found</h5>
                <p class="text-muted">Click "Add Employee" to create the first employee record.</p>
            </div>
        }
        else
        {
            <div class="table-responsive">
                <table class="table table-hover table-striped align-middle">
                    <thead class="table-light">
                        <tr>
                            <th>Full Name</th>
                            <th>Email</th>
                            <th>Mobile</th>
                            <th>Department</th>
                            <th>Job Title</th>
                            <th>Hire Date</th>
                            <th>Status</th>
                            <th class="text-center">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var employee in Model)
                        {
                            <tr>
                                <td class="fw-semibold">@employee.FullName</td>
                                <td>@employee.Email</td>
                                <td>@employee.MobileNumber</td>
                                <td><span class="badge bg-info text-white">@employee.DepartmentName</span></td>
                                <td>@employee.JobTitle</td>
                                <td>@employee.HireDate.ToString("MMM dd, yyyy")</td>
                                <td>
                                    @if (employee.IsActive)
                                    {
                                        <span class="badge bg-success">Active</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Inactive</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <a asp-action="Edit" asp-route-id="@employee.EmployeeId" class="btn btn-warning btn-sm">
                                        <i class="bi bi-pencil"></i> Edit
                                    </a>
                                    <form asp-action="Delete" asp-route-id="@employee.EmployeeId" method="post" class="d-inline" onsubmit="return confirm('Are you sure you want to delete this employee?');">
                                        @Html.AntiForgeryToken()
                                        <button type="submit" class="btn btn-danger btn-sm">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </form>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
</div>